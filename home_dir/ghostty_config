theme = ayu
font-size = 14
shell-integration = zsh
mouse-shift-capture = true
copy-on-select = clipboard
quit-after-last-window-closed = true
background-opacity = 0.95
unfocused-split-opacity = 0.7
split-divider-color = #555555
cursor-color = #00FF41
macos-titlebar-style = transparent

keybind = super+arrow_left=goto_split:previous
keybind = super+arrow_right=goto_split:next

keybind = super+shift+h=resize_split:left,10
keybind = super+shift+j=resize_split:down,10
keybind = super+shift+k=resize_split:up,10
keybind = super+shift+l=resize_split:right,10

keybind = super+shift+arrow_left=previous_tab
keybind = super+shift+arrow_right=next_tab

keybind = super+grave_accent=toggle_quick_terminal
